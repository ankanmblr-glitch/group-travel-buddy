rules_version = '2';

// Group Travel Buddy — Firestore security rules (v2)
//
// Trust model: trip code = invite. All devices are anonymously authenticated.
// Admin/participant distinction is enforced in the client UI (via URL key).
// Expenses: any signed-in user may update/delete any expense so the admin can
// correct or remove others' entries. Create still requires ownerUid to match
// so each expense is tied to the device that created it.
//
// Deploy: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /trips/{tripCode} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;

      match /expenses/{expenseId} {
        allow read: if signedIn();
        allow create: if signedIn()
                      && request.resource.data.ownerUid == request.auth.uid;
        // Any signed-in user may update or delete (admin needs this for
        // correcting others' entries; UI enforces the permission boundary).
        allow update, delete: if signedIn();
      }
    }
  }
}
